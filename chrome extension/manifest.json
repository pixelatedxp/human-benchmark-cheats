{
  "manifest_version": 3,
  "name": "Human Benchmark Bot",
  "version": "1.0",
  "description": "Premium auto-solver suite for Human Benchmark.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://humanbenchmark.com/*",
    "*://www.humanbenchmark.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Cheats Panel",
    "default_icon": "icons/icon16.png"
  }
}